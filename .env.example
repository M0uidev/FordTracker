FORDPASS_EMAIL=your@email.com
FORDPASS_PASSWORD=yourpassword
FORDPASS_VIN=                       # optional — auto-detected from first vehicle if blank
POLL_INTERVAL_SECONDS=180           # how often to poll (3 minutes default)
TRIP_TIMEOUT_MINUTES=10             # idle time before a trip is considered ended
MOVEMENT_THRESHOLD_METERS=50       # minimum movement to record a new GPS point
DB_PATH=fordtracker.db
